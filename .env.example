# ─────────────────────────────────────────────────────────────
# Пример переменных окружения для redmine-max-notifier.
# Скопируй в .env (`.env` в .gitignore) и подставь свои значения.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── База данных ──────────────────────────────────────────────
# Для локальной разработки — SQLite через aiosqlite.
# Файл БД появится в CWD при первом запуске (etap 6b).
DATABASE_URL=sqlite+aiosqlite:///./redmine_max_notifier.db

# Для прода — PostgreSQL через asyncpg:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/redmine_max_notifier
