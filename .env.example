# ─────────────────────────────────────────────────────────────
# Пример переменных окружения для redmine-max-notifier.
# Скопируй в .env (`.env` в .gitignore) и подставь свои значения.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── База данных ──────────────────────────────────────────────
# Для локальной разработки — SQLite через aiosqlite.
# Файл БД появится в CWD при первом запуске.
DATABASE_URL=sqlite+aiosqlite:///./redmine_max_notifier.db

# Для прода — PostgreSQL через asyncpg:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/redmine_max_notifier

# ── Redmine ──────────────────────────────────────────────────
# Базовый URL Redmine-инстанса, к которому ходит async-клиент.
# Без хвостового слэша.
REDMINE_URL=http://redmine.d-telekom.home

# API-ключ сервисного пользователя (My account → API access key).
REDMINE_API_KEY=replace-with-real-api-key

# Публичный URL Redmine для ссылок в сообщениях MAX.
# Часто совпадает с REDMINE_URL, но если сервис ходит во внутренний
# адрес, а пользователи — по внешнему, укажи внешний тут.
# Если оставить пустым — ссылки в сообщениях будут неполные.
REDMINE_BASE_URL_PUBLIC=http://redmine.d-telekom.home

# ── MAX ──────────────────────────────────────────────────────
# Токен бота (BotFather в MAX). Без префикса Bearer, просто токен.
MAX_TOKEN=replace-with-real-bot-token

# Путь до склеенного CA-bundle (certifi + сертификаты Госуслуг).
# Собирается: uv run python scripts/build_ca_bundle.py
# MAX_CA_BUNDLE_PATH=certs/ca_bundle.pem

# ── Поллер: свежие изменения ────────────────────────────────
# Как часто крутить задание (секунды). Минимум 10.
# POLL_INTERVAL_SECONDS=60

# Запас окна updated_on относительно last_check_at (секунды).
# Защищает от пропуска событий из-за рассинхрона часов.
# POLLING_LOOKBACK_SECONDS=300

# TTL кэша "id статуса → name" (секунды).
# STATUS_CACHE_TTL_SECONDS=3600

# ── Поллер: дедлайны ────────────────────────────────────────
# За сколько дней до due_date шлём напоминание.
# DUE_DATE_THRESHOLD_DAYS=3

# В какой час гонять ежедневное задание "дедлайны" (0-23).
# Час считается в TIMEZONE (см. ниже), а не в таймзоне ОС.
# DUE_DATE_JOB_HOUR=9

# ── Время ───────────────────────────────────────────────────
# Бизнес-таймзона сервиса: в ней считается час запуска задания
# "дедлайны" и то, какой сегодня день при сравнении с due_date.
# Имя из базы IANA. Задаётся явно, чтобы поведение не зависело
# от таймзоны ОС: прод-серверы принято держать в UTC, и тогда
# "9 утра" молча превратилось бы в полдень.
# TIMEZONE=Europe/Moscow
